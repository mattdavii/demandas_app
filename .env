# ===== BANCO DE DADOS (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname

# ===== SEGURANÇA / JWT =====
# Gere uma chave forte: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=troque-por-uma-chave-aleatoria-forte

# ===== EMAIL (para recuperação de senha) =====
# Use uma "Senha de App" do Gmail, não sua senha normal.
# Como gerar: Conta Google > Segurança > Verificação em duas etapas > Senhas de app
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=senha-de-app-do-gmail
MAIL_DEFAULT_SENDER=seu-email@gmail.com

# ===== URLs =====
# Usada no link de recuperação de senha enviado por email
FRONTEND_URL=https://seu-app.onrender.com

# ===== FLASK =====
FLASK_ENV=production
PORT=5000
